---
import { Image } from "astro:assets";
import Github from "../icons/Github.astro";
import Tool from "./Tool.astro";

interface Props {
  project: {
    title: string;
    description: string;
    github: string;
    website?: string;
    image: ImageMetadata;
    tools: string[];
    status?: "completed" | "in-progress";
  };
  index: number;
  delayStep?: number;
  maxTools?: number;
}

const { project, index, delayStep = 100, maxTools } = Astro.props;
const displayTools = maxTools
  ? project.tools.slice(0, maxTools)
  : project.tools;
const remainingTools =
  maxTools && project.tools.length > maxTools
    ? project.tools.length - maxTools
    : 0;

const statusLabel = project.status === "in-progress" ? "En Progreso" : "Completado";
const cardHref = project.website || project.github;
---

<li
  class="project-item"
  data-animate="fade-up"
  transition:name={`card-${project.title}`}
  style={`--delay: ${index * delayStep}ms`}
>
  <a
    href={cardHref}
    target="_blank"
    rel="noopener noreferrer"
    class="project-card-link"
  >
    <div class="project-img-wrapper">
      <Image
        src={project.image}
        alt={`Screenshot of ${project.title} — ${project.description}`}
        class="project-img"
        width={280}
        height={180}
      />
    </div>
    <div class="project-info">
      <div class="project-header">
        <h3 class="project-title txt-5 font-semibold">{project.title}</h3>
        <span class="project-status" data-status={project.status}>
          <span class="status-dot"></span>
          {statusLabel}
        </span>
      </div>
      <p class="project-description txt-6">{project.description}</p>
      <ul class="project-tools">
        {
          displayTools.map((tool) => (
            <li>
              <Tool name={tool} data-sm data-square />
            </li>
          ))
        }
        {
          remainingTools > 0 && (
            <li class="tools-more">+{remainingTools}</li>
          )
        }
      </ul>
    </div>
  </a>
  <a
    href={project.github}
    target="_blank"
    rel="noopener noreferrer"
    class="project-github"
    aria-label={`View ${project.title} on GitHub`}
  >
    <Github />
  </a>
</li>

<style>
  .project-item {
    display: flex;
    align-items: center;
    border: 1px solid var(--lines-grid-color);
    border-radius: var(--radius-xl);
    background-color: #fff;
    padding-right: 1.25rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;

    &:hover {
      border-color: var(--color-primary-20);
      box-shadow: 0 8px 24px -4px rgba(37, 99, 235, 0.08);
      transform: translateY(-2px);
    }

    &:hover .project-img {
      transform: scale(1.03);
    }

    &:hover .project-github {
      color: var(--color-primary);
      background-color: var(--color-primary-5);
      border-color: var(--color-primary-20);
    }
  }

  .project-card-link {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1rem;
    flex: 1;
    text-decoration: none;
    color: inherit;
    min-width: 0;
  }

  .project-img-wrapper {
    width: 220px;
    height: 140px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    flex-shrink: 0;
    background-color: #f8fafc;
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .project-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex-grow: 1;
    min-width: 0;
  }

  .project-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .project-title {
    color: var(--color-heading);
  }

  .project-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 10px;
    border-radius: var(--radius-full);
    font-size: 0.7rem;
    font-family: "JetBrains";
    font-weight: var(--font-medium);
    white-space: nowrap;
  }

  .project-status[data-status="completed"] {
    background-color: rgba(16, 185, 129, 0.08);
    color: #059669;
  }

  .project-status[data-status="in-progress"] {
    background-color: rgba(245, 158, 11, 0.08);
    color: #d97706;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: currentColor;
  }

  .project-status[data-status="in-progress"] .status-dot {
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .project-description {
    color: var(--color-gray);
    line-height: 1.5;
  }

  .project-tools {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 0.25rem;
    flex-wrap: wrap;
  }

  .tools-more {
    padding: 3px 8px;
    border-radius: var(--radius-full);
    color: var(--color-gray);
    font-size: 0.65rem;
    font-family: "JetBrains";
  }

  .project-github {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gray);
    flex-shrink: 0;
    margin-left: auto;
    transition: color 0.2s ease;
  }

  .project-github:hover {
    color: var(--color-primary);
  }

  @media screen and (width <= 768px) {
    .project-item {
      flex-direction: column;
      padding-right: 0;
      padding-bottom: 1rem;
    }

    .project-card-link {
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
    }

    .project-img-wrapper {
      width: 100%;
      height: 180px;
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    }

    .project-info {
      padding-inline: 0.5rem;
    }

    .project-github {
      margin: 0 1rem 0 auto;
    }
  }

  @media screen and (width <= 480px) {
    .project-img-wrapper {
      height: 150px;
    }

    .project-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>
