---
import { Image } from "astro:assets";
import Github from "../icons/Github.astro";
import Tool from "./Tool.astro";

interface Props {
  project: {
    title: string;
    description: string;
    github: string;
    website: string;
    image: ImageMetadata;
    tools: string[];
  };
  index: number;
  delayStep?: number;
  maxTools?: number;
}

const { project, index, delayStep = 100, maxTools } = Astro.props;
const displayTools = maxTools
  ? project.tools.slice(0, maxTools)
  : project.tools;
const remainingTools =
  maxTools && project.tools.length > maxTools
    ? project.tools.length - maxTools
    : 0;
---

<li
  class="project-item"
  data-animate="fade-up"
  style={`--delay: ${index * delayStep}ms`}
>
  <a
    href={project.website}
    target="_blank"
    rel="noopener noreferrer"
    class="project-card-link"
  >
    <Image
      src={project.image}
      alt={`Screenshot of ${project.title} — ${project.description}`}
      class="project-img"
      width={200}
      height={150}
    />
    <div class="project-info">
      <h3 class="project-title txt-5">{project.title}</h3>
      <p class="project-description txt-6">{project.description}</p>
      <ul class="project-tools">
        {
          displayTools.map((tool) => (
            <li>
              <Tool name={tool} data-md />
            </li>
          ))
        }
        {
          remainingTools > 0 && (
            <li class="tools-more txt-7">+{remainingTools}</li>
          )
        }
      </ul>
    </div>
  </a>
  <a
    href={project.github}
    target="_blank"
    rel="noopener noreferrer"
    class="project-github"
  >
    <Github />
  </a>
</li>

<style>
  .project-item {
    display: flex;
    width: 100%;
    align-items: center;
    gap: 2rem;
    box-shadow: var(--shadow-sm);
    padding-right: 16px;
    background-color: #fff;
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow 0.3s ease;

    &:hover {
      box-shadow: var(--shadow-lg);
    }
  }

  .project-card-link {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex: 1;
    text-decoration: none;
    color: inherit;
    min-width: 0;
  }

  .project-img {
    width: 200px;
    height: 150px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .project-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex-grow: 1;
    min-width: 0;
    padding-block: 12px;
  }

  .project-description {
    color: var(--color-gray);
  }

  .project-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .tools-more {
    padding: 3px 8px;
    border-radius: var(--radius-full);
    color: var(--color-gray);
    font-size: 0.65rem;
    font-family: "JetBrains";
  }

  .project-github {
    color: var(--color-primary);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  @media screen and (width <= 768px) {
    .project-item {
      flex-direction: column;
      padding-right: 0;
      padding-bottom: 16px;
      gap: 0;
    }

    .project-card-link {
      flex-direction: column;
      gap: 0;
      align-items: flex-start;
    }

    .project-img {
      width: 100%;
      height: 180px;
    }

    .project-info {
      padding: 12px 16px 0;
    }

    .project-github {
      padding: 8px 16px 0;
    }
  }

  @media screen and (width <= 480px) {
    .project-img {
      height: 150px;
    }
  }
</style>
