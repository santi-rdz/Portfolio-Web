---
interface Props {
  href: string;
}

const { href } = Astro.props;
---

<div class="view-all-wrap">
  <a href={href} class="view-all-link txt-mono-2"><slot /></a>
</div>

<style>
  .view-all-wrap {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }

  .view-all-link {
    color: var(--color-primary);
    text-decoration: none;
    letter-spacing: 2px;
    transition: opacity 0.2s ease;
  }

  .view-all-link:hover {
    opacity: 0.7;
  }
</style>
