---
const { class: className, as, ...props } = Astro.props;
---

{
  as ? (
    <as class:list={["link", className]} {...props}>
      <slot />
    </as>
  ) : (
    <a class:list={["link", className]} {...props}>
      <slot />
    </a>
  )
}

<style>
  .link {
    display: inline-block;
    color: var(--color-gray);
    text-decoration: none;
    transition: color 0.3s ease;
    cursor: pointer;
    position: relative;
  }
  .link[data-cta] {
    color: var(--color-primary);
    border: 1.5px solid var(--color-primary);
    padding: 11px 20px;
    border-radius: var(--radius-md);
    overflow: hidden;
    font-weight: var(--font-semibold);
    letter-spacing: 0.3px;
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0);
    transition:
      all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.35s ease;
  }
  .link[data-cta][lg] {
    padding: 16px 30px;
  }
  /* Animated fill effect */
  .link[data-cta]::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-20));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: -1;
    border-radius: inherit;
  }
  .link[data-cta]:hover {
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
  }
  .link[data-cta]:hover::before {
    transform: scaleX(1);
  }
  .link[data-cta]:active {
    transform: translateY(0px);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.25);
  }
  .link[data-mono] {
    font-family: "JetBrains", monospace;
  }
  .link[data-md] {
    font-size: var(--font-7);
    padding: 12px 16px;
  }
  /* fill left → right */
  .link[data-cta][data-slide]::before {
    transform: scaleX(0);
    transform-origin: left;
  }
  .link[data-cta][data-slide]:hover::before {
    transform: scaleX(1);
  }
  .link[data-cta]::after {
    display: none;
  }
  .link:hover {
    color: var(--color-primary);
  }

  .link::after {
    content: "";
    position: absolute;
    width: 100%;
    height: 2px;
    left: 0;
    bottom: -2px;
    background-color: var(--color-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .link:hover::after {
    transform: scaleX(1);
  }
</style>
