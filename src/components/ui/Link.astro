---
const { class: className, as, ...props } = Astro.props;
---

{
  as ? (
    <as class:list={["link", className]} {...props}>
      <slot />
    </as>
  ) : (
    <a class:list={["link", className]} {...props}>
      <slot />
    </a>
  )
}

<style>
  .link {
    display: inline-block;
    color: var(--color-gray);
    text-decoration: none;
    transition: color 0.3s ease;
    cursor: pointer;
    position: relative;
  }
  /* CTA Base - Default: filled by default (inverted effect) */
  .link[data-cta] {
    color: #fff;
    border: 1.5px solid transparent;
    padding: 11px 20px;
    border-radius: var(--radius-md);
    overflow: hidden;
    font-weight: var(--font-semibold);
    letter-spacing: 0.3px;
    box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
    transform: translateY(-2px);
    transition:
      all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.35s ease;
  }
  .link[data-cta][lg] {
    padding: 16px 30px;
  }
  .link[data-cta]::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #2563eb, #3b82f6);
    transform: scaleX(1);
    transform-origin: center;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: -1;
    border-radius: inherit;
  }
  /* Default: bottom-to-up effect */
  .link[data-cta]:not([data-fill]) {
    color: #fff;
    border-color: transparent;
    box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
    transform: translateY(-2px);
  }
  .link[data-cta]:not([data-fill])::before {
    transform: scaleY(1);
    transform-origin: bottom;
  }
  .link[data-cta]:not([data-fill]):hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    transform: translateY(0px);
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.15);
  }
  .link[data-cta]:not([data-fill]):hover::before {
    transform: scaleY(0);
  }
  .link[data-cta]:not([data-fill]):active {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.25);
  }

  /* Fill left → right on hover */
  .link[data-cta][data-fill="left-to-right"] {
    color: #fff;
    border-color: transparent;
    box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
    transform: translateY(-2px);
  }
  .link[data-cta][data-fill="left-to-right"]::before {
    transform: scaleX(1);
    transform-origin: right;
  }
  .link[data-cta][data-fill="left-to-right"]:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    transform: translateY(0px);
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.15);
  }
  .link[data-cta][data-fill="left-to-right"]:hover::before {
    transform: scaleX(0);
  }

  /* Fill bottom → top on hover */
  .link[data-cta][data-fill="bottom-to-up"] {
    color: #fff;
    border-color: transparent;
    box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
    transform: translateY(-2px);
  }
  .link[data-cta][data-fill="bottom-to-up"]::before {
    transform: scaleY(1);
    transform-origin: bottom;
  }
  .link[data-cta][data-fill="bottom-to-up"]:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    transform: translateY(0px);
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.15);
  }
  .link[data-cta][data-fill="bottom-to-up"]:hover::before {
    transform: scaleY(0);
  }

  .link[data-cta]::after {
    display: none;
  }
  .link[data-mono] {
    font-family: "JetBrains", monospace;
  }
  .link[data-md] {
    font-size: var(--font-7);
    padding: 12px 16px;
  }

  /* Default link hover underline */
  .link:not([data-cta]):hover {
    color: var(--color-primary);
  }

  .link:not([data-cta])::after {
    content: "";
    position: absolute;
    width: 100%;
    height: 2px;
    left: 0;
    bottom: -2px;
    background-color: var(--color-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .link:not([data-cta]):hover::after {
    transform: scaleX(1);
  }
</style>
