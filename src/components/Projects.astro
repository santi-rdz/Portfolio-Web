---
import { Image } from "astro:assets";
import Heading from "./Heading.astro";
import Github from "./icons/Github.astro";
import Tool from "./Tool.astro";
import { projects } from "../data/projects";

const preview = projects.slice(0, 3);
---

<section id="projects" class="projects-scetion center-section">
  <div class="container">
    <Heading as="h2">Projects</Heading>
    <ul class="project-list">
      {
        preview.map((project, i) => (
          <li class="project-item" data-animate="fade-up" style={`--delay: ${i * 100}ms`}>
            <a href={project.website} target="_blank" rel="noopener noreferrer" class="project-card-link">
              <Image src={project.image} alt={project.title} class="project-img" width={200} height={150} />
              <div class="project-info">
                <h3 class="project-title txt-5">{project.title}</h3>
                <p class="project-description txt-6">{project.description}</p>
                <ul class="project-tools">
                  {project.tools.slice(0, 4).map((tool) => <li><Tool name={tool} data-md /></li>)}
                  {project.tools.length > 4 && <li class="tools-more txt-7">+{project.tools.length - 4}</li>}
                </ul>
              </div>
            </a>
            <a
              href={project.github}
              target="_blank"
              rel="noopener noreferrer"
              class="project-github"
              onclick="event.stopPropagation()"
            >
              <Github />
            </a>
          </li>
        ))
      }
    </ul>
    <div class="view-all-wrap">
      <a href="/projects" class="view-all-link txt-mono-2">View All &rarr;</a>
    </div>
  </div>
</section>

<style>
  .project-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 2rem;
  }

  .project-item {
    display: flex;
    width: 100%;
    align-items: center;
    gap: 2rem;
    box-shadow: var(--shadow-sm);
    padding-right: 16px;
    background-color: #fff;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .project-card-link {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex: 1;
    text-decoration: none;
    color: inherit;
    min-width: 0;
  }

  .project-img {
    width: 200px;
    height: 150px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .project-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex-grow: 1;
    min-width: 0;
  }

  .project-description {
    color: var(--color-gray);
  }

  .project-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }

  .tools-more {
    padding: 3px 8px;
    border-radius: var(--radius-full);
    color: var(--color-gray);
    font-size: 0.65rem;
    font-family: "JetBrains";
  }

  .project-github {
    color: var(--color-primary);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .view-all-wrap {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }

  .view-all-link {
    color: var(--color-primary);
    text-decoration: none;
    letter-spacing: 2px;
    transition: opacity 0.2s ease;
  }

  .view-all-link:hover {
    opacity: 0.7;
  }

  @media screen and (width <= 768px) {
    .project-list {
      gap: 1.25rem;
    }

    .project-item {
      flex-direction: column;
      padding-right: 0;
      padding-bottom: 16px;
      gap: 0;
    }

    .project-card-link {
      flex-direction: column;
      gap: 0;
      align-items: flex-start;
    }

    .project-img {
      width: 100%;
      height: 180px;
    }

    .project-info {
      padding: 12px 16px 0;
    }

    .project-github {
      padding: 8px 16px 0;
    }
  }

  @media screen and (width <= 480px) {
    .project-img {
      height: 150px;
    }
  }
</style>
