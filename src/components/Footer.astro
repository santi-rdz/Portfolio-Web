<footer class="main-footer">
  <div class="lg-container footer-container">
    <p>Designed and built by Raul Rodriguez.</p>
    <p>&copy; {new Date().getFullYear()} My Portfolio. All rights reserved.</p>
  </div>
</footer>

<style>
  .main-footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 10;
    border-top: 1px solid var(--lines-grid-color);
    background-color: #fff;
  }
  .footer-container {
    padding-block: 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--color-gray);
    font-size: var(--font-7);
  }

  @media screen and (width <= 768px) {
    .footer-container {
      flex-direction: column;
      gap: 0.25rem;
      text-align: center;
      padding-block: 0.75rem;
    }
  }
</style>

<script>
  const footer = document.querySelector(".main-footer") as HTMLElement;
  const hero = document.querySelector(".hero-section");

  if (footer && hero) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        footer.style.backgroundColor = entry.isIntersecting
          ? "#f5f5f5"
          : "#fff";
      },
      { threshold: 0.5 },
    );
    observer.observe(hero);
  }
</script>
