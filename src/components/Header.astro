---
import Link from "./ui/Link.astro";
import Github from "./icons/Github.astro";
import Linkedin from "./icons/Linkedin.astro";
import Mail from "./icons/Mail.astro";
---

<header class="main-header">
  <nav class="nav lg-container">
    <a href="/" class="logo">&lt;RR /&gt;</a>
    <button
      class="nav-toggle"
      aria-label="Toggle navigation"
      aria-expanded="false"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <ul class="nav-ul">
      <li class="nav-logo-item">
        <a href="/" class="logo">&lt;RR /&gt;</a>
      </li>
      <li><Link href="/#about">About</Link></li>
      <li><Link href="/#experience">Experience</Link></li>
      <li><Link href="/#projects">Projects</Link></li>
      <li><Link href="/#skills">Skills</Link></li>
      <li><Link href="/#contact">Contact</Link></li>
      <li>
        <Link href="/resume" data-cta>Resume</Link>
      </li>
      <li class="nav-socials">
        <a href="https://github.com/santi-rdz" target="_blank" rel="noopener noreferrer">
          <Github />
        </a>
        <a href="https://linkedin.com/in/raul-rodriguez-169911369" target="_blank" rel="noopener noreferrer">
          <Linkedin />
        </a>
        <a href="mailto:raul2003santiago@gmail.com" target="_blank" rel="noopener noreferrer">
          <Mail />
        </a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .main-header {
    padding-block: 1.5rem;
    width: 100%;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 10;
    border-bottom: 1px solid transparent;
    transition:
      padding-block 0.3s ease,
      background-color 0.3s ease,
      border-color 0.3s ease;
  }

  .main-header.scrolled {
    padding-block: 0.5rem;
    background-color: var(--color-white, #fff);
    border-bottom-color: var(--lines-grid-color);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .logo {
    color: var(--color-primary);
    text-decoration: none;
    flex-shrink: 0;
    font-size: var(--font-5);
    font-weight: var(--font-semibold);
  }

  .logo:hover,
  .logo:focus {
    color: var(--color-primary);
    text-decoration: none;
  }

  .nav-toggle {
    display: none;
  }

  .nav-logo-item {
    display: none;
  }

  .nav-socials {
    display: none;
  }

  @media screen and (width <= 768px) {
    .main-header {
      padding-inline: 0;
      z-index: 20;
    }

    .nav-toggle {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
      z-index: 20;
      position: relative;
    }

    .nav-toggle span {
      display: block;
      width: 24px;
      height: 2px;
      background-color: var(--color-heading);
      border-radius: 2px;
      transition: transform 0.3s ease, opacity 0.3s ease;
    }

    .nav-toggle.is-open {
      position: fixed;
      top: 1rem;
      right: 1.5rem;
      z-index: 17;
    }

    .nav-toggle.is-open span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .nav-toggle.is-open span:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle.is-open span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    .nav-ul {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      width: 100%;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      background-color: var(--color-white, #fff);
      padding: 5rem 1.5rem 2rem;
      z-index: 16;
      overflow-y: auto;
      text-align: center;
      transform: translateX(-100%);
      transition: transform 0.3s ease;
      visibility: hidden;
    }

    .nav-ul.is-open {
      transform: translateX(0);
      visibility: visible;
    }

    body.nav-open::before {
      content: "";
      position: fixed;
      inset: 0;
      background-color: rgba(0, 0, 0, 0.3);
      z-index: 15;
    }

    .nav-logo-item {
      display: block;
      width: 100%;
      margin-bottom: 0.5rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--lines-grid-color);
    }

    .nav-socials {
      display: flex;
      gap: 1.2rem;
      justify-content: center;
      width: 100%;
      margin-top: auto;
    }

    .nav-socials a {
      color: var(--color-gray);
      display: flex;
      padding: 8px;
      border-radius: var(--radius-md);
      transition: color 0.3s ease, transform 0.3s ease;
    }

    .nav-socials a:hover {
      color: var(--color-primary);
      transform: translateY(-3px);
    }

    .nav-socials :global(.media-icon) {
      width: 20px;
      height: 20px;
    }
  }

  @media screen and (width <= 480px) {
    .main-header {
      padding-block: 1rem;
    }
  }
</style>

<script>
  function initHeader() {
    const header = document.querySelector(".main-header");
    const hero = document.querySelector(".hero-section");
    const toggle = document.querySelector(".nav-toggle");
    const navUl = document.querySelector(".nav-ul");

    if (!header) return;

    // Scroll effect
    if (hero) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          header.classList.toggle("scrolled", !entry.isIntersecting);
        },
        { threshold: 0.5 },
      );
      observer.observe(hero);
    } else {
      header.classList.add("scrolled");
    }

    // Mobile menu
    if (!toggle || !navUl) return;

    const closeNav = () => {
      navUl.classList.remove("is-open");
      toggle.classList.remove("is-open");
      toggle.setAttribute("aria-expanded", "false");
      document.body.classList.remove("nav-open");
    };

    const openNav = () => {
      navUl.classList.add("is-open");
      toggle.classList.add("is-open");
      toggle.setAttribute("aria-expanded", "true");
      document.body.classList.add("nav-open");
    };

    toggle.addEventListener("click", () => {
      navUl.classList.contains("is-open") ? closeNav() : openNav();
    });

    navUl.querySelectorAll("a:not(.nav-logo)").forEach((link) => {
      link.addEventListener("click", closeNav);
    });

    document.addEventListener("click", (e) => {
      if (navUl.classList.contains("is-open") &&
          !navUl.contains(e.target) &&
          !toggle.contains(e.target)) {
        closeNav();
      }
    });
  }

  document.addEventListener("astro:page-load", initHeader);
</script>
