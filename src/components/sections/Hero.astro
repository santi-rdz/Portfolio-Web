---
import Link from "../ui/Link.astro";
import me from "../../assets/me.png";
import { Image } from "astro:assets";
---

<section class="hero-section">
  <div class="orb orb--1"></div>
  <div class="orb orb--2"></div>
  <div class="orb orb--3"></div>
  <div class="container hero-container">
    <div class="hero-info">
      <span
        class="txt-7 hero-intro font-jetbrains"
        data-animate="fade-up"
        style="--delay: 0ms">Hi, my name is</span
      >
      <h1
        class="hero-title txt-1"
        data-animate="fade-up"
        style="--delay: 100ms"
      >
        Raul Rodriguez
      </h1>
      <h2
        class="hero-subtitle txt-2 color-primary"
        data-animate="fade-up"
        style="--delay: 200ms"
      >
        Web Developer
      </h2>
      <p class="hero-description" data-animate="fade-up" style="--delay: 300ms">
        I'm a web developer currently pursuing a degree in Software Engineering
        at <span class="color-primary font-medium"
          >Universidad Autonoma de Baja California</span
        >. I'm passionate in web development.
      </p>
      <Link
        href="#projects"
        class="hero-cta"
        data-button
        lg
        data-animate="fade-up"
        style="--delay: 400ms">View my Work &rarr;</Link
      >
    </div>
    <div class="hero-img" data-animate="fade-left" style="--delay: 200ms">
      <Image src={me} alt="Raul Rodriguez picture" />
    </div>
  </div>
  <div class="scroll">
    <p class="txt-mono-2">SCROLL</p>
    <span class="scroll-bar"></span>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--lines-grid-color);
  }

  .hero-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background-color: #f5f5f5;
    z-index: -1;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 60fr 40fr;
    align-items: center;
    gap: 2rem;
    min-height: 100dvh;
    padding-block: 100px 80px;
  }

  .hero-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .hero-intro {
    font-family: "JetBrains";
    color: var(--color-primary);
  }

  .hero-description {
    text-wrap: balance;
    color: var(--color-gray);
  }

  .hero-cta {
    font-family: "JetBrains";
    align-self: flex-start;
    margin-top: 48px;
  }

  .hero-img {
    margin-inline: auto;
    border: 1px solid var(--color-primary);
    padding: 16px;
    border-radius: var(--radius-lg);
    width: clamp(200px, 100%, 380px);
  }

  .hero-img img {
    border-radius: 8px;
    width: 100%;
    height: auto;
    display: block;
  }

  .orb {
    border-radius: 50%;
    position: absolute;
    pointer-events: none;
    z-index: 0;
    will-change: transform, opacity, filter;
  }

  .orb--1 {
    width: 500px;
    height: 500px;
    top: -10%;
    left: -5%;
    background: radial-gradient(
      circle at 40% 40%,
      rgba(37, 99, 235, 0.35),
      rgba(99, 102, 241, 0.1) 60%,
      transparent 80%
    );
    filter: blur(70px);
    animation: orbDrift1 10s cubic-bezier(0.45, 0, 0.55, 1) infinite;
  }

  .orb--2 {
    width: 420px;
    height: 420px;
    top: 30%;
    right: -5%;
    background: radial-gradient(
      circle at 60% 50%,
      rgba(37, 99, 235, 0.3),
      rgba(139, 92, 246, 0.08) 55%,
      transparent 75%
    );
    filter: blur(80px);
    animation: orbDrift2 12s cubic-bezier(0.45, 0, 0.55, 1) infinite;
    animation-delay: -5s;
  }

  .orb--3 {
    width: 280px;
    height: 280px;
    bottom: 10%;
    left: 35%;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(99, 102, 241, 0.2),
      transparent 70%
    );
    filter: blur(60px);
    animation: orbDrift3 8s cubic-bezier(0.45, 0, 0.55, 1) infinite;
    animation-delay: -3s;
  }

  @keyframes orbDrift1 {
    0%,
    100% {
      transform: translate(0px, 0px) scale(1);
      opacity: 0.7;
      filter: blur(70px);
    }
    35% {
      transform: translate(20px, -25px) scale(1.08);
      opacity: 1;
      filter: blur(55px);
    }
    70% {
      transform: translate(-10px, -12px) scale(0.95);
      opacity: 0.6;
      filter: blur(80px);
    }
  }

  @keyframes orbDrift2 {
    0%,
    100% {
      transform: translate(0px, 0px) scale(1);
      opacity: 0.65;
      filter: blur(80px);
    }
    40% {
      transform: translate(-25px, -20px) scale(1.1);
      opacity: 0.95;
      filter: blur(60px);
    }
    75% {
      transform: translate(12px, -8px) scale(0.93);
      opacity: 0.5;
      filter: blur(90px);
    }
  }

  @keyframes orbDrift3 {
    0%,
    100% {
      transform: translate(0px, 0px) scale(1);
      opacity: 0.5;
      filter: blur(60px);
    }
    45% {
      transform: translate(15px, -30px) scale(1.12);
      opacity: 0.85;
      filter: blur(45px);
    }
    80% {
      transform: translate(-8px, -15px) scale(0.9);
      opacity: 0.4;
      filter: blur(70px);
    }
  }

  .scroll {
    font-family: "JetBrains";
    position: fixed;
    bottom: 50px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    z-index: 20;
  }

  .scroll p {
    color: var(--color-gray);
    letter-spacing: 3px;
  }

  .scroll-bar {
    width: 2px;
    height: 40px;
    background-color: var(--lines-grid-color);
    border-radius: var(--radius-full);
    position: relative;
  }

  .scroll-bar::after {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: 20%;
    background-color: var(--color-primary);
    border-radius: var(--radius-full);
    animation: scrollAnim 1.5s ease-in-out infinite alternate;
  }

  @keyframes scrollAnim {
    0%,
    10% {
      top: 0;
      opacity: 1;
    }
    90%,
    100% {
      top: 80%;
      opacity: 1;
    }
  }

  @media screen and (width <= 768px) {
    .hero-container {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .hero-img {
      display: block;
      width: clamp(200px, 70%, 320px);
      margin-inline: auto;
      transform: none;
    }

    .hero-cta {
      margin-top: 32px;
    }

    .scroll {
      display: none;
    }

    .orb--1 {
      width: 320px;
      height: 320px;
    }

    .orb--2 {
      width: 260px;
      height: 260px;
    }

    .orb--3 {
      display: none;
    }
  }

  @media screen and (width <= 480px) {
    .hero-container {
      padding-block: 90px 48px;
    }

    .hero-cta {
      margin-top: 24px;
    }
  }
</style>
