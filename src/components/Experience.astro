---
import Heading from "./Heading.astro";
import { experience } from "../data/experience";

const preview = experience.slice(0, 3);
---

<section id="experience" class="experience-section center-section">
  <div class="experience-content container">
    <Heading as="h2">Experience</Heading>
    <ul class="experience-list">
      {
        preview.map((exp, i) => (
          <li class="experience-item" data-animate="fade-up" style={`--delay: ${i * 100}ms`}>
            <header class="experience-item--header">
              <div>
              <Heading as="h3">{exp.title}</Heading>
              {exp.duration && <span class="experience-duration">Duration: {exp.duration}</span>}
              </div>
              <span class="experience-source">{exp.learnSource}</span>
            </header>
            <ul class="experience-details">
              {exp.details.map((detail) => (
                <li class="experience-detail">{detail}</li>
              ))}
            </ul>
          </li>
        ))
      }
    </ul>
    <div class="experience-footer">
      <a href="/experience" class="view-all-link txt-mono-2">View All &rarr;</a>
    </div>
  </div>
</section>

<style>
  .experience-list {
    display: flex;
    flex-direction: column;
    
  }

  .experience-item {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 24px;
    border-left: 1px solid var(--lines-grid-color);

    &::before{
      content: '';
      position: absolute;
      left: 0;
      top: 24px;
      width: 10px;
      transform: translateX(-50%);
      height: 10px;
      border-radius: var(--radius-full);
      border: 2px solid var(--color-primary);
      background-color: #fff;
      }
  }
  .experience-item + .experience-item {
    border-top: 1px solid var(--lines-grid-color);
  }
  .experience-item--header{
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
   .experience-source{
      font-size: var(--font-7);
      color: var(--color-primary);
      font-family: 'JetBrains';
      
    }
  .experience-duration {
    font-size: var(--font-7);
    color: var(--color-gray);
  }
  .experience-details {
    display: flex
    flex-direction: column;
    line-height: 1.5;
    font-size: var(--font-6);
    color: var(--color-gray);
   
  }
  .experience-detail{
    text-wrap: balanced;
  }
  
  .experience-details li::before {
    content: "•";
    color: var(--color-primary);
    display: inline-block;
    width: 1ch;
  }

  .experience-footer {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }
  .view-all-link {
    color: var(--color-primary);
    text-decoration: none;
    letter-spacing: 2px;
    transition: opacity 0.2s ease;
  }
  .view-all-link:hover {
    opacity: 0.7;
  }

  @media screen and (width <= 768px) {
    .experience-item--header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }

  @media screen and (width <= 480px) {
    .experience-item {
      padding: 16px;
    }
  }
</style>
