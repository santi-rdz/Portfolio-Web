---
interface Props {
  sections: { id: string; label: string }[];
}

const { sections } = Astro.props;
---

<aside class="resume-sidebar">
  <div class="sidebar-header">On this page</div>
  <nav class="sidebar-nav">
    <ul class="sidebar-list">
      {sections.map((section) => (
        <li>
          <a href={`#${section.id}`} class="sidebar-link">
            {section.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<style>
  .resume-sidebar {
    position: fixed;
    left: 0;
    top: 100px;
    width: 160px;
    height: calc(100vh - 100px);
    overflow-y: auto;
    padding: 2rem 1.5rem 2rem 0;
  }

  .sidebar-header {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    color: var(--color-gray);
    margin-bottom: 1.5rem;
    padding-left: 1rem;
  }

  .sidebar-nav {
    padding: 0;
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sidebar-link {
    display: block;
    padding: 0.6rem 1rem;
    color: var(--color-gray);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s ease, border-left 0.2s ease;
    border-left: 3px solid transparent;
  }

  .sidebar-link:hover {
    color: var(--color-heading);
  }

  .sidebar-link.active {
    color: var(--color-heading);
    border-left-color: var(--color-primary);
    font-weight: 500;
  }

  @media screen and (width <= 1200px) {
    .resume-sidebar {
      display: none;
    }
  }

  @media screen and (width <= 768px) {
    .resume-sidebar {
      display: none;
    }
  }
</style>

<script>
  function initSidebarLinks() {
    const links = document.querySelectorAll(".sidebar-link");
    const headerHeight = 130;

    function updateActiveLink() {
      const headings = document.querySelectorAll(".resume-content h2, .resume-content h3");
      let closestHeading = null;
      let closestDistance = Infinity;

      headings.forEach((heading) => {
        if (!heading.id) return;

        const rect = heading.getBoundingClientRect();
        const distance = Math.abs(rect.top - headerHeight);

        if (distance < closestDistance) {
          closestDistance = distance;
          closestHeading = heading;
        }
      });

      if (closestHeading) {
        links.forEach((link) => link.classList.remove("active"));
        const activeLink = document.querySelector(
          `.sidebar-link[href="#${closestHeading.id}"]`
        );
        if (activeLink) {
          activeLink.classList.add("active");
        }
      }
    }

    // Initial check
    updateActiveLink();

    // Update on scroll
    window.addEventListener("scroll", updateActiveLink);

    // Handle click navigation
    links.forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const href = link.getAttribute("href");
        if (!href) return;

        const targetId = href.slice(1);
        const target = document.getElementById(targetId);

        if (target) {
          const targetPosition = target.getBoundingClientRect().top + window.scrollY - headerHeight;
          window.scrollTo({
            top: targetPosition,
            behavior: "smooth",
          });
        }
      });
    });
  }

  document.addEventListener("astro:page-load", initSidebarLinks);
</script>
