---
interface Props {
  sections: { id: string; label: string }[];
}

const { sections } = Astro.props;
---

<aside class="resume-sidebar">
  <div class="sidebar-header">On this page</div>
  <nav class="sidebar-nav">
    <ul class="sidebar-list">
      {sections.map((section) => (
        <li>
          <a href={`#${section.id}`} class="sidebar-link">
            {section.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<style>
  .resume-sidebar {
    position: fixed;
    left: 0;
    top: 100px;
    width: 160px;
    height: calc(100vh - 100px);
    overflow-y: auto;
    padding: 2rem 1.5rem 2rem 0;
  }

  .sidebar-header {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    color: var(--color-gray);
    margin-bottom: 1.5rem;
    padding-left: 1rem;
  }

  .sidebar-nav {
    padding: 0;
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sidebar-link {
    display: block;
    padding: 0.6rem 1rem;
    color: var(--color-gray);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s ease, border-left 0.2s ease;
    border-left: 3px solid transparent;
  }

  .sidebar-link:hover {
    color: var(--color-heading);
  }

  .sidebar-link.active {
    color: var(--color-heading);
    border-left-color: var(--color-primary);
    font-weight: 500;
  }

  @media screen and (width <= 1200px) {
    .resume-sidebar {
      display: none;
    }
  }

  @media screen and (width <= 768px) {
    .resume-sidebar {
      display: none;
    }
  }
</style>

<script>
  function initSidebarLinks() {
    const links = document.querySelectorAll(".sidebar-link");
    const headerHeight = 130;

    // Set first link as active on page load
    if (links.length > 0) {
      links[0].classList.add("active");
    }

    links.forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const href = link.getAttribute("href");
        if (!href) return;

        const targetId = href.slice(1);
        const target = document.getElementById(targetId);

        if (target) {
          // Mark as active
          links.forEach((l) => l.classList.remove("active"));
          link.classList.add("active");

          // Scroll to section
          const targetPosition = target.getBoundingClientRect().top + window.scrollY - headerHeight;
          window.scrollTo({
            top: targetPosition,
            behavior: "smooth",
          });
        }
      });
    });
  }

  document.addEventListener("astro:page-load", initSidebarLinks);
</script>
