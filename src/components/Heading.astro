---
const { as } = Astro.props;
---

<as class="heading" data-as={as}>
  <slot />
</as>

<style>
  .heading {
    display: flex;
    align-items: center;
    gap: 8px;
    text-overflow: wrap;
  }
  .heading[data-as="h1"] {
    font-size: var(--font-3);
    font-weight: var(--font-bold);
  }
  .heading[data-as="h2"] {
    font-size: var(--font-4);
    font-weight: var(--font-bold);
    margin-bottom: 78px;
    text-wrap: nowrap;
  }
  @media screen and (width <= 768px) {
    .heading[data-as="h2"] {
      margin-bottom: 48px;
    }
  }
  @media screen and (width <= 480px) {
    .heading[data-as="h2"] {
      margin-bottom: 24px;
    }
  }
  .heading[data-as="h2"]::before,
  .heading[data-as="h5"]::before {
    content: "/";
    color: var(--color-primary);
  }

  .heading[data-as="h2"]::after {
    content: "";
    display: inline-block;
    width: 100%;
    height: 1px;
    background-color: var(--lines-grid-color);
    margin-left: 20px;
  }
  .heading[data-as="h3"] {
    font-size: var(--font-5);
    font-weight: var(--font-medium);
  }
  .heading[data-as="h4"] {
    font-size: var(--font-6);
    font-weight: var(--font-medium);
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 1.4px;
  }
  .heading[data-as="h5"] {
    font-size: var(--font-6);
    font-weight: var(--font-medium);
    color: var(--color-primary);
  }
</style>
