---
const { class: className, as, ...props } = Astro.props;
---

{
  as ? (
    <as class:list={["link", className]} {...props}>
      <slot />
    </as>
  ) : (
    <a class:list={["link", className]} {...props}>
      <slot />
    </a>
  )
}

<style>
  .link {
    display: inline-block;
    color: var(--color-gray);
    text-decoration: none;
    transition: color 0.3s ease;
    cursor: pointer;
    position: relative;
  }
  .link[data-cta] {
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
    padding: 10px 18px;
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: color 0.3s ease;
  }
  .link[data-cta][lg] {
    padding: 16px 30px;
  }
  /* Default: fill bottom → top */
  .link[data-cta]::before {
    content: "";
    position: absolute;
    inset: 0;
    background-color: var(--color-primary);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.3s ease;
    z-index: -1;
    border-radius: inherit;
  }
  .link[data-cta]:hover {
    color: #fff;
  }
  .link[data-cta]:hover::before {
    transform: scaleY(1);
  }
  .link[data-mono] {
    font-family: "JetBrains", monospace;
  }
  .link[data-md] {
    font-size: var(--font-7);
    padding: 12px 16px;
  }
  /* fill left → right */
  .link[data-cta][data-slide]::before {
    transform: scaleX(0);
    transform-origin: left;
  }
  .link[data-cta][data-slide]:hover::before {
    transform: scaleX(1);
  }
  .link[data-cta]::after {
    display: none;
  }
  .link:hover {
    color: var(--color-primary);
  }

  .link::after {
    content: "";
    position: absolute;
    width: 100%;
    height: 2px;
    left: 0;
    bottom: -2px;
    background-color: var(--color-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .link:hover::after {
    transform: scaleX(1);
  }
</style>
