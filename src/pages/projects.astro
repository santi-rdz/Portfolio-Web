---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import ProjectCard from "../components/ui/ProjectCard.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Projects — Raul Rodriguez"
  description="Web development projects by Raul Rodriguez. Built with React, TailwindCSS, Node.js, and more. Includes CAIS patient system, Recipe Finder, Dictionary app, and Countries app."
>
  <main class="projects-page">
    <div class="container projects-page-content">
      <PageHeader backHref="/#projects" title="Projects" />
      <ul class="project-list">
        {
          projects.map((project, i) => (
            <ProjectCard project={project.data} index={i} delayStep={80} />
          ))
        }
      </ul>
    </div>
  </main>
</Layout>

<style>
  .projects-page {
    min-height: 100dvh;
    padding-top: 100px;
    padding-bottom: 80px;
  }

  .project-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media screen and (width <= 768px) {
    .project-list {
      gap: 1.25rem;
    }
  }
</style>
