---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Heading from "../components/Heading.astro";
import Github from "../components/icons/Github.astro";
import Link from "../components/Link.astro";
import Tool from "../components/Tool.astro";
import { projects } from "../data/projects";
---

<Layout>
  <Header />
  <main class="projects-page">
    <div class="container projects-page-content">
      <div class="projects-page-header" data-animate="fade-up">
        <Link href="/#projects" data-cta data-slide>&larr; Back</Link>
        <Heading as="h2">Projects</Heading>
      </div>
      <ul class="project-list">
        {
          projects.map((project, i) => (
            <li class="project-item" data-animate="fade-up" style={`--delay: ${i * 80}ms`}>
              <a
                href={project.website}
                target="_blank"
                rel="noopener noreferrer"
                class="project-card-link"
              >
                <Image
                  src={project.image}
                  alt={project.title}
                  class="project-img"
                  width={200}
                  height={150}
                />
                <div class="project-info">
                  <h3 class="project-title txt-5">{project.title}</h3>
                  <p class="project-description txt-6">{project.description}</p>
                  <ul class="project-tools">
                    {project.tools.map((tool) => (
                      <li>
                        <Tool name={tool} data-md />
                      </li>
                    ))}
                  </ul>
                </div>
              </a>
              <a
                href={project.github}
                target="_blank"
                rel="noopener noreferrer"
                class="project-github"
              >
                <Github />
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .projects-page {
    min-height: 100dvh;
    padding-top: 100px;
    padding-bottom: 80px;
  }

  .projects-page-header {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .project-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .project-item {
    display: flex;
    width: 100%;
    align-items: center;
    gap: 2rem;
    box-shadow: var(--shadow-sm);
    padding-right: 16px;
    background-color: #fff;
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow 0.3s ease;

    &:hover {
      box-shadow: var(--shadow-lg);
    }
  }

  .project-card-link {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex: 1;
    text-decoration: none;
    color: inherit;
    min-width: 0;
  }

  .project-img {
    width: 200px;
    height: 150px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .project-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex-grow: 1;
    min-width: 0;
    padding-block: 12px;
  }

  .project-description {
    color: var(--color-gray);
  }

  .project-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .project-github {
    color: var(--color-primary);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  @media screen and (width <= 768px) {
    .project-list {
      gap: 1.25rem;
    }

    .project-item {
      flex-direction: column;
      padding-right: 0;
      padding-bottom: 16px;
      gap: 0;
    }

    .project-card-link {
      flex-direction: column;
      gap: 0;
      align-items: flex-start;
    }

    .project-img {
      width: 100%;
      height: 180px;
    }

    .project-info {
      padding: 12px 16px 0;
    }

    .project-github {
      padding: 8px 16px 0;
    }
  }

  @media screen and (width <= 480px) {
    .project-img {
      height: 150px;
    }
  }
</style>
