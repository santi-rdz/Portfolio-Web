---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Link from "../components/ui/Link.astro";
import { marked } from "marked";
import resumeContent from "../assets/resume.md?raw";

const slugify = (text: string) =>
  text
    .toLowerCase()
    .trim()
    .replace(/[^\w\s-]/g, "")
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-");

const renderer = new marked.Renderer();
renderer.heading = ({ text, depth }) => {
  const slug = slugify(text);
  return `<h${depth} id="${slug}">${text}</h${depth}>`;
};

marked.setOptions({ renderer });
const renderedContent = marked(resumeContent);
---

<Layout>
  <Header />
  <main class="resume-page">
    <div class="container resume-container">
      <div class="resume-header" data-animate="fade-up">
        <div class="resume-controls">
          <Link href="/" data-cta data-slide>&larr; Back</Link>
          <button id="download-btn" class="download-btn" data-cta
            >Download</button
          >
        </div>
      </div>
      <article class="resume-content">
        <Fragment set:html={renderedContent} />
      </article>
    </div>
  </main>
</Layout>

<style>
  .resume-page {
    min-height: 100dvh;
    padding-top: 100px;
    padding-bottom: 80px;
  }

  .resume-container {
    max-width: 900px;
  }

  .resume-header {
    margin-bottom: 2rem;
  }

  .resume-controls {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .download-btn {
    padding: 10px 18px;
    border: 1px solid var(--color-primary);
    background-color: var(--color-primary);
    color: #fff;
    border-radius: var(--radius-md);
    cursor: pointer;
    font-family: "JetBrains", monospace;
    font-size: var(--font-7);
    transition: background-color 0.3s ease;
  }

  .download-btn:hover {
    background-color: var(--color-primary);
    opacity: 0.8;
  }

  .download-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .resume-content {
    font-size: 0.95rem;
    color: var(--color-gray);
    line-height: 1.6;
  }

  .resume-content :global(h1) {
    font-size: 1.75rem;
    font-weight: var(--font-bold);
    color: var(--color-heading);
    margin-top: 0;
    margin-bottom: 0.25rem;
    letter-spacing: -0.5px;
  }

  .resume-content :global(h1 + p) {
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    color: var(--color-gray);
  }

  .resume-content :global(h2) {
    font-size: 0.95rem;
    font-weight: var(--font-bold);
    color: var(--color-heading);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: inline-block;
    border-bottom: 1px solid var(--color-gray);
    padding-bottom: 0.25rem;
  }

  .resume-content :global(h3) {
    font-size: 1rem;
    font-weight: var(--font-semibold);
    color: var(--color-heading);
    margin-top: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .resume-content :global(h3 + p) {
    margin-top: 0;
    font-size: 0.9rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .resume-content :global(p) {
    margin-bottom: 0.75rem;
    text-wrap: balance;
  }

  .resume-content :global(ul) {
    margin: 0.5rem 0 0.75rem 1.5rem;
    padding: 0;
  }

  .resume-content :global(li) {
    margin-bottom: 0.35rem;
    list-style: disc;
    color: var(--color-gray);
  }

  .resume-content :global(strong) {
    color: var(--color-heading);
    font-weight: 600;
  }

  .resume-content :global(em) {
    color: var(--color-primary);
    font-style: italic;
  }

  .resume-content :global(a) {
    color: var(--color-primary);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .resume-content :global(a:hover) {
    opacity: 0.8;
    text-decoration: underline;
  }

  .resume-content :global(hr) {
    border: none;
    border-top: 1px solid var(--lines-grid-color);
    margin: 1rem 0;
  }

  .resume-content :global(mark) {
    background: none;
    color: inherit;
    border-bottom: 2px solid var(--color-primary);
    padding-bottom: 2px;
    font-weight: 500;
  }

  @media screen and (width <= 768px) {
    .resume-page {
      padding-top: 90px;
      padding-bottom: 60px;
    }

    .resume-container {
      padding: 0 1rem;
    }

    .resume-content {
      font-size: 0.9rem;
    }

    .resume-content :global(h2) {
      font-size: 0.9rem;
      margin-top: 1.25rem;
    }

    .resume-content :global(h3) {
      font-size: 0.95rem;
      margin-top: 0.5rem;
    }
  }

  @media screen and (width <= 480px) {
    .resume-page {
      padding-top: 80px;
      padding-bottom: 48px;
    }

    .resume-content {
      font-size: 0.85rem;
    }

    .resume-content :global(h1) {
      font-size: 1.5rem;
    }

    .resume-content :global(h2) {
      font-size: 0.85rem;
      margin-top: 1rem;
      margin-bottom: 0.5rem;
    }

    .resume-content :global(ul) {
      margin-left: 1.25rem;
    }

    .resume-controls {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
  function initDownloadBtn() {
    const btn = document.getElementById("download-btn");
    if (!btn) return;

    btn.addEventListener("click", () => {
      const element = document.querySelector(".resume-content");
      if (!element) return;

      btn.disabled = true;
      btn.textContent = "Generating...";

      const options = {
        margin: [0.5, 0.75, 0.5, 0.75],
        filename: "Raul_Rodriguez_Resume.pdf",
        image: { type: "jpeg", quality: 0.98 },
        html2canvas: {
          scale: 2,
          useCORS: true,
          logging: false,
        },
        jsPDF: {
          orientation: "portrait",
          unit: "in",
          format: "letter",
        },
        pagebreak: {
          mode: ["avoid-all", "css"],
          avoid: ["h2", "h3", ".resume-content ul"],
        },
      };

      html2pdf()
        .set(options)
        .from(element)
        .save()
        .then(() => {
          btn.disabled = false;
          btn.textContent = "Download";
        })
        .catch((error) => {
          console.error("PDF Error:", error.message);
          btn.disabled = false;
          btn.textContent = "Download";
          alert("Failed to generate PDF");
        });
    });
  }

  document.addEventListener("astro:page-load", initDownloadBtn);
</script>
