---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Link from "../components/ui/Link.astro";
import { marked } from "marked";
import resumeContent from "../assets/resume.md?raw";
---

<Layout>
  <Header />
  <main class="resume-page">
    <div class="container resume-container">
      <div class="resume-header" data-animate="fade-up">
        <div class="resume-controls">
          <Link href="/" data-cta data-slide>&larr; Back</Link>
          <button id="download-btn" class="download-btn" data-cta
            >Download</button
          >
        </div>
      </div>
      <article class="resume-content">
        <Fragment set:html={marked(resumeContent)} />
      </article>
    </div>
  </main>
</Layout>

<style>
  .resume-page {
    min-height: 100dvh;
    padding-top: 100px;
    padding-bottom: 80px;
  }

  .resume-container {
    max-width: 900px;
  }

  .resume-header {
    margin-bottom: 2rem;
  }

  .resume-controls {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .download-btn {
    padding: 10px 18px;
    border: 1px solid var(--color-primary);
    background-color: var(--color-primary);
    color: #fff;
    border-radius: var(--radius-md);
    cursor: pointer;
    font-family: "JetBrains", monospace;
    font-size: var(--font-7);
    transition: background-color 0.3s ease;
  }

  .download-btn:hover {
    background-color: var(--color-primary);
    opacity: 0.8;
  }

  .download-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .resume-content {
    font-size: var(--font-6);
    color: var(--color-gray);
    line-height: 1.8;
  }

  .resume-content :global(h1) {
    font-size: var(--font-1);
    font-weight: var(--font-bold);
    color: var(--color-heading);
    margin-top: 0;
    margin-bottom: 0.5rem;
  }

  .resume-content :global(h2) {
    font-size: var(--font-4);
    font-weight: var(--font-bold);
    color: var(--color-heading);
    margin-top: 2rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--lines-grid-color);
  }

  .resume-content :global(h3) {
    font-size: var(--font-5);
    font-weight: var(--font-semibold);
    color: var(--color-heading);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .resume-content :global(p) {
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .resume-content :global(ul) {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .resume-content :global(li) {
    margin-bottom: 0.5rem;
    list-style: disc;
  }

  .resume-content :global(strong) {
    color: var(--color-heading);
    font-weight: var(--font-semibold);
  }

  .resume-content :global(em) {
    color: var(--color-primary);
    font-style: italic;
  }

  .resume-content :global(a) {
    color: var(--color-primary);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .resume-content :global(a:hover) {
    opacity: 0.7;
    text-decoration: underline;
  }

  .resume-content :global(hr) {
    border: none;
    border-top: 1px solid var(--lines-grid-color);
    margin: 2rem 0;
  }

  @media screen and (width <= 768px) {
    .resume-page {
      padding-top: 90px;
      padding-bottom: 60px;
    }

    .resume-content :global(h2) {
      font-size: var(--font-5);
      margin-top: 1.5rem;
    }

    .resume-content :global(h3) {
      font-size: var(--font-6);
      margin-top: 1rem;
    }
  }

  @media screen and (width <= 480px) {
    .resume-page {
      padding-top: 80px;
      padding-bottom: 48px;
    }

    .resume-content :global(h1) {
      font-size: var(--font-3);
    }

    .resume-content :global(h2) {
      font-size: var(--font-5);
    }

    .resume-controls {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
  function initDownloadBtn() {
    const btn = document.getElementById("download-btn");
    if (!btn) return;

    btn.addEventListener("click", () => {
      const element = document.querySelector(".resume-content");
      if (!element) return;

      btn.disabled = true;
      btn.textContent = "Generating...";

      const options = {
        margin: 10,
        filename: "Raul_Rodriguez_Resume.pdf",
        image: { type: "jpeg", quality: 0.98 },
        html2canvas: { scale: 2 },
        jsPDF: { orientation: "portrait", unit: "mm", format: "a4" },
      };

      html2pdf()
        .set(options)
        .from(element)
        .save()
        .then(() => {
          btn.disabled = false;
          btn.textContent = "Download";
        })
        .catch((error) => {
          console.error("Error generating PDF:", error);
          btn.disabled = false;
          btn.textContent = "Download";
        });
    });
  }

  document.addEventListener("astro:page-load", initDownloadBtn);
</script>
