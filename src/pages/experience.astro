---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import ExperienceItem from "../components/ui/ExperienceItem.astro";
import { getCollection } from "astro:content";

const allExperience = await getCollection("experience");
const experience = allExperience.sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Experience — Raul Rodriguez"
  description="Professional experience and learning path of Raul Rodriguez. Includes social service at UABC, web development courses, and self-taught frontend and backend skills."
>
  <main class="experience-page">
    <div class="container experience-page-content">
      <PageHeader backHref="/#experience" title="Experience" />
      <ul class="experience-list">
        {
          experience.map((exp, i) => (
            <ExperienceItem
              title={exp.data.title}
              duration={exp.data.duration}
              learnSource={exp.data.learnSource}
              details={exp.data.details}
              index={i}
              delayStep={80}
            />
          ))
        }
      </ul>
    </div>
  </main>
</Layout>

<style>
  .experience-page {
    min-height: 100dvh;
    padding-top: 100px;
    padding-bottom: 80px;
  }

  .experience-list {
    display: flex;
    flex-direction: column;
  }
</style>
